# Telegram Bot (обов'язково для сповіщень про ліди)
# 1. Відкрийте @BotFather у Telegram
# 2. Надішліть /newbot та отримайте токен
TG_TOKEN=your_bot_token_here

# Telegram Chat ID
# 1. Напишіть @userinfobot у Telegram
# 2. Скопіюйте ваш ID
TG_CHAT_ID=your_chat_id_here

# Google Analytics (опціонально)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
